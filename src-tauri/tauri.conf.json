{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Musicbox",
  "version": "0.1.0",
  "identifier": "com.dennistrue.musicbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Musicbox",
        "width": 1580,
        "height": 1040,
        "minWidth": 1280,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}

